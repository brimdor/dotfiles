#!/bin/bash

# Set the path to your dotfiles repository
DOTFILES_DIR="$HOME/dotfiles"
BREWFILE="$DOTFILES_DIR/Brewfile"

# Function to display the main menu
main_menu() {
  clear
  echo "=== Update Menu ==="
  echo "1. Configuration"
  echo "2. Brew"
  echo "3. Cask"
  echo "4. Exit"
  echo -n "Please choose an option [1-4]: "
  read -r main_choice
  case $main_choice in
    1) type="Configuration"; action_menu ;;
    2) type="Brew"; action_menu ;;
    3) type="Cask"; action_menu ;;
    4) exit 0 ;;
    *) echo "Invalid option. Please try again." ; sleep 1 ; main_menu ;;
  esac
}

# Function to display the action menu
action_menu() {
  clear
  echo "=== $type Menu ==="
  echo "1. Add"
  echo "2. Remove"
  echo "3. Return to previous menu"
  echo -n "Please choose an option [1-3]: "
  read -r action_choice
  case $action_choice in
    1) add_$type ;;
    2) remove_$type ;;
    3) main_menu ;;
    *) echo "Invalid option. Please try again." ; sleep 1 ; action_menu ;;
  esac
}

# Function to add a Configuration
add_Configuration() {
  echo -n "Enter the name of the new configuration: "
  read -r config_name
  config_dir="$DOTFILES_DIR/$config_name"
  if [ -d "$config_dir" ]; then
    echo "Configuration '$config_name' already exists."
    sleep 2
    action_menu
  fi
  mkdir -p "$config_dir"
  echo "Enter the configuration lines (end with EOF on a new line):"
  config_lines=""
  while IFS= read -r line; do
    [ "$line" == "EOF" ] && break
    config_lines+="$line"$'\n'
  done
  # Save configuration lines to a file in the new configuration directory
  config_file="$config_dir/$config_name.conf"
  echo "$config_lines" > "$config_file"
  # Update the install script to symlink the new configuration
  echo "ln -sfn \$DOTFILES/$config_name/$(basename "$config_file") \$HOME/.${config_name}" >> "$DOTFILES_DIR/install"
  echo "Configuration '$config_name' added successfully."
  sleep 2
  action_menu
}

# Function to remove a Configuration
remove_Configuration() {
  # List existing configurations
  configs=($(find "$DOTFILES_DIR" -maxdepth 1 -type d -not -path "$DOTFILES_DIR" -exec basename {} \;))
  if [ ${#configs[@]} -eq 0 ]; then
    echo "No configurations found."
    sleep 2
    action_menu
  fi
  echo "Select a configuration to remove:"
  select config_name in "${configs[@]}" "Cancel"; do
    if [ "$config_name" == "Cancel" ]; then
      action_menu
    elif [ -n "$config_name" ]; then
      # Remove configuration directory
      rm -rf "$DOTFILES_DIR/$config_name"
      # Remove symlink command from install script
      sed -i.bak "/\$DOTFILES\/$config_name/d" "$DOTFILES_DIR/install"
      echo "Configuration '$config_name' removed successfully."
      sleep 2
      action_menu
    else
      echo "Invalid selection."
    fi
  done
}

# Function to add a Brew formula
add_Brew() {
  echo -n "Enter the name of the Brew formula to add: "
  read -r formula
  # Check if formula exists
  if brew search "^$formula$" | grep -q "^$formula$"; then
    if grep -q "brew \"$formula\"" "$BREWFILE"; then
      echo "Formula '$formula' is already in the Brewfile."
    else
      echo "brew \"$formula\"" >> "$BREWFILE"
      echo "Formula '$formula' added to the Brewfile."
    fi
  else
    echo "Formula '$formula' not found in Homebrew."
  fi
  sleep 2
  action_menu
}

# Function to remove a Brew formula
remove_Brew() {
  # List Brew formulas from Brewfile
  formulas=($(grep '^brew ' "$BREWFILE" | awk '{print $2}' | tr -d '"'))
  if [ ${#formulas[@]} -eq 0 ]; then
    echo "No Brew formulas found in the Brewfile."
    sleep 2
    action_menu
  fi
  echo "Select a Brew formula to remove:"
  select formula in "${formulas[@]}" "Cancel"; do
    if [ "$formula" == "Cancel" ]; then
      action_menu
    elif [ -n "$formula" ]; then
      # Remove formula from Brewfile
      sed -i.bak "/brew \"$formula\"/d" "$BREWFILE"
      echo "Formula '$formula' removed from the Brewfile."
      sleep 2
      action_menu
    else
      echo "Invalid selection."
    fi
  done
}

# Function to add a Cask application
add_Cask() {
  echo -n "Enter the name of the Cask application to add: "
  read -r cask
  # Check if cask exists
  if brew search --casks "^$cask$" | grep -q "^$cask$"; then
    if grep -q "cask \"$cask\"" "$BREWFILE"; then
      echo "Cask '$cask' is already in the Brewfile."
    else
      echo "cask \"$cask\"" >> "$BREWFILE"
      echo "Cask '$cask' added to the Brewfile."
    fi
  else
    echo "Cask '$cask' not found in Homebrew."
  fi
  sleep 2
  action_menu
}

# Function to remove a Cask application
remove_Cask() {
  # List Casks from Brewfile
  casks=($(grep '^cask ' "$BREWFILE" | awk '{print $2}' | tr -d '"'))
  if [ ${#casks[@]} -eq 0 ]; then
    echo "No Casks found in the Brewfile."
    sleep 2
    action_menu
  fi
  echo "Select a Cask to remove:"
  select cask in "${casks[@]}" "Cancel"; do
    if [ "$cask" == "Cancel" ]; then
      action_menu
    elif [ -n "$cask" ]; then
      # Remove cask from Brewfile
      sed -i.bak "/cask \"$cask\"/d" "$BREWFILE"
      echo "Cask '$cask' removed from the Brewfile."
      sleep 2
      action_menu
    else
      echo "Invalid selection."
    fi
  done
}

# Start the script
main_menu
